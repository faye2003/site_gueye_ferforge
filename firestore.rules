rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: services
    // Fields: title (string), description (string), fullDescription (string), prestations (list), image (string), gallery (list), order (number), status (string)
    //
    // Collection: realizations
    // Fields: title (string), category (string), description (string), images (list), location (string), date (string), status (string)
    //
    // Collection: messages
    // Fields: name (string), phone (string), service (string), message (string), createdAt (timestamp)
    //
    // Collection: categories
    // Fields: name (string)
    //
    // Collection: settings
    // Fields: whatsappNumber (string), whatsappText (string), whatsappPosition (string), whatsappActive (bool)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "fayem7409@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    match /realizations/{realizationId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAdmin();
      allow create: if isValidString('name', 1, 100) && 
                       isValidString('phone', 1, 20) && 
                       isValidString('message', 1, 1000);
      allow update, delete: if isAdmin();
    }
  }
}
